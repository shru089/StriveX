# StriveX Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git!

# ============ REQUIRED ============

# Secret key for JWT token signing
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_KEY_64_CHARS

# ============ CORS ============
# Your deployed frontend URL (e.g. https://strivex.netlify.app)
CORS_ORIGIN=http://localhost:3001

# ============ DATABASE ============
# SQLite (default for local dev):
DATABASE_URL=sqlite:///strivex.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/strivex_db

# ============ UPGRADE 1: Gemini AI ============
# Free API key from: https://aistudio.google.com/app/apikey
# If not set, app falls back to rule-based logic
GEMINI_API_KEY=

# ============ UPGRADE 4: Sentry (error tracking) ============
# Free at: https://sentry.io — create a Flask project, copy the DSN
# If not set, error tracking is disabled
SENTRY_DSN=

# ============ UPGRADE 5: Google OAuth ============
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============ SERVER ============
PORT=5001
