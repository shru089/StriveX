# ════════════════════════════════════════════════════════════
# ═════════════════ STRIPE CONFIGURATION ════════════════════
# ════════════════════════════════════════════════════════════

# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Webhook secret - get from Stripe CLI or Dashboard after creating endpoint
# Run: stripe listen --forward-to localhost:5001/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Product Price IDs from Stripe Dashboard (after creating products)
# Create products at: https://dashboard.stripe.com/products
STRIPE_PRICE_PREMIUM=price_premium_monthly_id_here
STRIPE_PRICE_PRO=price_pro_monthly_id_here

# ════════════════════════════════════════════════════════════
# ═══════════════ EXISTING CONFIGURATION ════════════════════
# ════════════════════════════════════════════════════════════

SECRET_KEY=your_secure_random_secret_key_min_32_chars
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=sqlite:///strivex.db

# Gemini AI (Google AI Studio)
# You can provide multiple keys separated by commas for fallback rotation if you hit rate limits
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2

# Google OAuth (Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Sentry (Error Tracking - Optional)
SENTRY_DSN=your_sentry_dsn_here

# Email (SendGrid - Optional for daily digests)
SENDGRID_API_KEY=your_sendgrid_api_key

# Logging (set to 'none' to disable file logging)
LOG_FILE=strivex.log
