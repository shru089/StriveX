# StriveX Environment Variables

# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production

# Database (SQLite by default, can change to PostgreSQL later)
# DATABASE_URL=sqlite:///strivex.db

# CORS (for production, set to your frontend URL)
# CORS_ORIGIN=https://your-frontend-domain.com

# Debug Mode (set to False in production)
# FLASK_DEBUG=True
