# Copy to frontend-react/.env and fill in your values
# NEVER commit the actual .env file to git!

# ============ Gemini AI (FREE - no billing required) ============
# Get a FREE key at: https://aistudio.google.com/app/apikey
# Without this key, the app uses the built-in smart scheduler instead.
VITE_GEMINI_KEY=

# ============ API URL ============
# Leave empty for local dev (uses Vite proxy to localhost:5001)
# Set to your deployed backend URL in production
VITE_API_URL=
