{
    "version": 2,
    "builds": [
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/sw.js",
            "dest": "/frontend/sw.js",
            "headers": {
                "Cache-Control": "no-cache, no-store, must-revalidate",
                "Service-Worker-Allowed": "/"
            }
        },
        {
            "src": "/manifest.json",
            "dest": "/frontend/manifest.json",
            "headers": {
                "Cache-Control": "public, max-age=86400"
            }
        },
        {
            "src": "/icons/(.*)",
            "dest": "/frontend/icons/$1",
            "headers": {
                "Cache-Control": "public, max-age=2592000, immutable"
            }
        },
        {
            "src": "/css/(.*)",
            "dest": "/frontend/css/$1",
            "headers": {
                "Cache-Control": "public, max-age=2592000, immutable"
            }
        },
        {
            "src": "/js/(.*)",
            "dest": "/frontend/js/$1",
            "headers": {
                "Cache-Control": "public, max-age=2592000, immutable"
            }
        },
        {
            "src": "/dashboard.html",
            "dest": "/frontend/dashboard.html"
        },
        {
            "src": "/onboarding.html",
            "dest": "/frontend/onboarding.html"
        },
        {
            "src": "/offline.html",
            "dest": "/frontend/offline.html"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "geolocation=(), microphone=(self)"
                }
            ]
        }
    ]
}