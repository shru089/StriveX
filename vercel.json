{
    "version": 2,
    "builds": [
        {
            "src": "frontend-react/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/sw.js",
            "dest": "/frontend-react/public/sw.js",
            "headers": {
                "Cache-Control": "no-cache, no-store, must-revalidate",
                "Service-Worker-Allowed": "/"
            }
        },
        {
            "src": "/manifest.json",
            "dest": "/frontend-react/public/manifest.json"
        },
        {
            "src": "/icons/(.*)",
            "dest": "/frontend-react/public/icons/$1"
        },
        {
            "src": "/api/(.*)",
            "dest": "https://your-backend.railway.app/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend-react/dist/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
            ]
        }
    ]
}